# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TEMPERATURE=0.1
SUITABILITY_TEMPERATURE=0.0

# LangSmith Tracing
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls-...
LANGCHAIN_PROJECT=wealth-manager-copilot

# ChromaDB
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION_NAME=wealth_management_knowledge

# FAISS
FAISS_INDEX_PATH=./data/faiss_index

# Agent Controls
AGENT_MAX_STEPS=10
AGENT_MAX_TOTAL_STEPS=30

# Data Paths
CLIENT_DATA_PATH=./data/clients/clients.json
MARKET_DATA_PATH=./data/raw/market_data.json
RAW_DOCS_DIR=./data/raw

# Streamlit
STREAMLIT_PORT=8501
